# 协同服务器环境变量配置

# 服务器端口（Railway 必须设置为 8080）
PORT=8080

# 服务器监听地址
HOST=0.0.0.0

# Redis 连接 URL（可选，用于多实例同步）
# 格式：redis://[:password]@host:port
# 示例：redis://localhost:6379
# Railway Redis 示例：redis://default:password@redis.railway.internal:6379
REDIS_URL=

# LevelDB 数据路径
DB_PATH=./data/yjs-db

# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info
