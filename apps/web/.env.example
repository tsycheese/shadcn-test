# 数据库连接字符串
# 示例：postgresql://user:password@localhost:5432/shadcn_editor
DATABASE_URL=postgresql://user:password@localhost:5432/shadcn_editor

# NextAuth 配置
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-replace-with-random-string

# 邮件配置
RESEND_API_KEY=re_your-resend-api-key-here
MAIL_FROM=noreply@yourapp.com
SITE_NAME=Collab Editor

# WebSocket 协同服务器地址
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Github OAuth 配置
AUTH_GITHUB_ID=your_client_id_here
AUTH_GITHUB_SECRET=your_client_secret_here