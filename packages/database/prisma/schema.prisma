// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 权限级别枚举
enum Permission {
  READ      // 只读
  WRITE     // 可编辑
  ADMIN     // 管理员
}

// 邀请状态枚举
enum InvitationStatus {
  PENDING   // 待处理
  ACCEPTED  // 已接受
  REJECTED  // 已拒绝
  EXPIRED   // 已过期
}

// 用户模型
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  passwordHash  String?
  image         String?

  // Auth.js 关系
  accounts Account[]
  sessions Session[]

  // 业务关系
  documents         Document[]           @relation("DocumentOwner")
  collaborations    DocumentCollaborator[] @relation("UserCollaborations")
  invitationsSent   DocumentInvitation[]   @relation("InvitationsSent")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
}

// Auth.js - OAuth 账户表
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Auth.js - 会话表（使用 database session 策略时需要）
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// 邮箱验证令牌
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// 密码重置令牌
model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
}

// 文档模型
model Document {
  id            String    @id @default(uuid())
  title         String    @default("未命名文档")
  content       Bytes?    // Yjs 二进制快照
  ownerId       String
  owner         User      @relation("DocumentOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  collaborators DocumentCollaborator[] @relation("DocumentCollaborators")
  invitations   DocumentInvitation[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([ownerId])
}

// 协作者表
model DocumentCollaborator {
  id         String   @id @default(uuid())
  documentId String
  userId     String
  permission Permission @default(READ)

  document   Document @relation("DocumentCollaborators", fields: [documentId], references: [id], onDelete: Cascade)
  user       User     @relation("UserCollaborations", fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // 确保同一用户不能重复协作同一文档
  @@unique([documentId, userId])
  @@index([userId])
  @@index([documentId])
}

// 文档邀请表
model DocumentInvitation {
  id         String           @id @default(uuid())
  documentId String
  email      String
  permission Permission        @default(READ)
  status     InvitationStatus @default(PENDING)
  token      String           @unique
  expires    DateTime

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  invitedBy  String
  inviter    User     @relation("InvitationsSent", fields: [invitedBy], references: [id], onDelete: Cascade)

  createdAt  DateTime  @default(now())
  acceptedAt DateTime?

  @@index([token])
  @@index([documentId])
  @@index([email])
}
